# URL de Google Apps Script para procesar el envío de formularios (voluntarios, residencias, adultos mayores)
PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/OTRO_HASH_AQUÍ/exec

# Enlace al perfil de Cafecito del cliente para recibir donaciones
