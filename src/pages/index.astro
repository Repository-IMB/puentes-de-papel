---
import '../styles/global.css';
import { Play, Heart, Users, MessageCircle, BookOpen, Star, Sparkles, ArrowRight, UserPlus, Send, Menu, Mail, Clock, PenTool, Building } from 'lucide-astro';

const title = 'Puentes de Papel - Munay Ruray';
const description = 'Conectando generaciones a través de historias y memorias. Puentes de Papel une a jóvenes voluntarios con personas mayores para compartir historias de vida, rescatar memorias y generar vínculos significativos.';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/puentes-de-papel-conversacion-parque-adulto-mayor-voluntaria.webp', Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Joven voluntaria conversando con adulto mayor en parque — Puentes de Papel" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- SEO adicional -->
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#A65F4C" />

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/images/logo.webp" />

    <!-- JSON-LD: Organización y WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Munay Ruray",
          "url": "https://munayruray.com"
        },
        {
          "@type": "WebSite",
          "name": "Puentes de Papel",
          "alternateName": "Puentes de Papel - Munay Ruray",
          "url": String(canonicalURL),
          "description": description,
          "publisher": { "@id": "https://munayruray.com" },
          "inLanguage": "es-PE"
        }
      ]})} />

    <!-- Import Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
    <script is:inline>
      if (typeof window !== 'undefined') {
        window.addEventListener('DOMContentLoaded', () => {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('sr-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            {
              threshold: 0.2,
            }
          );

          document
            .querySelectorAll('.sr-fade-up, .sr-fade-up-delayed')
            .forEach((el) => observer.observe(el));
        });
      }
    </script>
  </head>

  <body>
    <div class="min-h-screen font-sans text-slate-800 overflow-hidden" style="font-family: 'Nunito', sans-serif;">
      <div class="bg-[#F2EADD]">
        <!-- --- Navigation Bar (Optional but good for context) --- -->
        <header class="container mx-auto px-6 py-6 relative z-10">
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-48 bg-transparent flex items-center justify-center">
                <img src="/images/logo-horizontal.png" alt="Logo de Puentes de Papel" class="w-full h-full object-cover mix-blend-multiply" />
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="hidden md:flex gap-8 font-semibold text-slate-600">
                <a href="#sobre-el-proyecto" class="hover:text-[#A65F4C] transition-colors">Sobre el proyecto</a>
                <a href="#como-funciona" class="hover:text-[#A65F4C] transition-colors">¿Cómo funciona?</a>
                <a href="#formas-de-participar" class="hover:text-[#A65F4C] transition-colors">Formas de participar</a>
                <a href="#quienes-somos" class="hover:text-[#A65F4C] transition-colors">Quiénes somos</a>
              </div>
              <label
                for="alternar-menu"
                class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full bg-white shadow-sm border border-slate-200 text-slate-700 hover:bg-[#F2EADD] hover:text-[#A65F4C] transition-colors cursor-pointer"
                aria-label="Abrir menú de navegación"
              >
                <Menu class="w-6 h-6" />
              </label>
            </div>
          </div>
          <input id="alternar-menu" type="checkbox" class="peer hidden" />
          <nav class="mt-4 bg-white rounded-2xl shadow-lg p-4 space-y-3 peer-checked:block hidden md:hidden">
            <a href="#sobre-el-proyecto" class="block px-2 py-2 rounded-xl font-semibold text-slate-700 hover:bg-[#F2EADD] hover:text-[#A65F4C] transition-colors">
              Sobre el proyecto
            </a>
            <a href="#como-funciona" class="block px-2 py-2 rounded-xl font-semibold text-slate-700 hover:bg-[#F2EADD] hover:text-[#A65F4C] transition-colors">
              ¿Cómo funciona?
            </a>
            <a href="#formas-de-participar" class="block px-2 py-2 rounded-xl font-semibold text-slate-700 hover:bg-[#F2EADD] hover:text-[#A65F4C] transition-colors">
              Formas de participar
            </a>
            <a href="#quienes-somos" class="block px-2 py-2 rounded-xl font-semibold text-slate-700 hover:bg-[#F2EADD] hover:text-[#A65F4C] transition-colors">
              Quiénes somos
            </a>
          </nav>
        </header>
  
        <!-- --- 1. Hero Section --- -->
        <section class="container mx-auto px-6 pt-12 pb-24 md:pt-20 md:pb-32 relative sr-fade-up">
          <!-- Decorative Background Blobs -->
          <div class="absolute top-0 left-0 w-96 h-96 bg-[#DD8574] rounded-full mix-blend-multiply filter blur-[128px] opacity-30"></div>
          <div class="absolute top-0 right-0 w-96 h-96 bg-amber-200 rounded-full mix-blend-multiply filter blur-[128px] opacity-40"></div>
  
          <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20 relative z-10">
            
            <!-- Left Column: Text -->
            <div class="w-full md:w-1/2 flex flex-col items-start text-left sr-fade-up-delayed">
              <div class="inline-flex items-center gap-2 bg-white border border-[#DD8574]/40 px-4 py-2 rounded-full mb-6">
                <span class="flex h-2 w-2 rounded-full bg-[#A65F4C]"></span>
                <span class="text-sm font-bold text-[#A65F4C] tracking-wide uppercase">Un proyecto de Munay Ruray</span>
              </div>
              
              <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-slate-900 leading-[1.1] mb-6">
                Puentes <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#A65F4C] to-[#DD8574]">de Papel</span>
              </h1>
              
              <h2 class="text-xl md:text-2xl font-semibold text-slate-600 mb-6 leading-relaxed">
                Conectando generaciones a través de historias y memorias.
              </h2>
              
              <p class="text-xl text-slate-500 mb-10 leading-relaxed max-w-xl">
                Puentes de Papel es una iniciativa que busca unir a jóvenes voluntarios con personas mayores para compartir historias de vida, rescatar memorias y generar vínculos significativos entre generaciones.
              </p>
              
              <div class="flex flex-col sm:flex-row items-center gap-6 w-full sm:w-auto">
                <a href="#formas-de-participar" class="cursor-pointer w-full sm:w-auto bg-[#A65F4C] text-white text-lg font-bold px-8 py-4 rounded-full hover:bg-[#DD8574] hover:-translate-y-1 transition-all duration-300">
                  Descubre cómo participar
                </a>
                <a href="#como-funciona" class="cursor-pointer w-full sm:w-auto group flex items-center justify-center gap-3 text-slate-700 font-bold text-lg hover:text-[#A65F4C] transition-colors">
                  <div class="w-12 h-12 rounded-full bg-white border border-slate-100 flex items-center justify-center group-hover:bg-[#F2EADD] transition-colors">
                    <Sparkles class="w-5 h-5 text-[#A65F4C]" />
                  </div>
                  Conocer más
                </a>
              </div>
            </div>
  
            <!-- Right Column: Image/Illustration -->
            <div class="w-full md:w-1/2 relative sr-fade-up-delayed">
              <!-- Floating decorative elements -->
              <div class="absolute -top-8 -left-8 bg-white border border-slate-100 p-3 rounded-2xl z-20">
                <Sparkles class="w-8 h-8 text-amber-400" />
              </div>
              <div class="absolute -bottom-6 -right-6 bg-white border border-slate-100 p-4 rounded-full z-20">
                <Heart class="w-8 h-8 text-rose-400 fill-rose-400" />
              </div>
              
              <!-- Main Image Masked -->
              <div class="relative rounded-[3rem] overflow-hidden border-8 border-white">
                <div class="absolute inset-0 bg-[#A65F4C]/10 mix-blend-overlay z-10"></div>
                <img 
                  src="/images/puentes-de-papel-conversacion-parque-adulto-mayor-voluntaria.webp" 
                  alt="Un adulto mayor y una joven voluntaria conversan animadamente sentados en una banca de parque durante una sesión del proyecto Puentes de Papel"
                  title="Joven voluntaria conversando con adulto mayor en parque — Puentes de Papel"
                  aria-label="Encuentro intergeneracional al aire libre en el proyecto Puentes de Papel de Munay Ruray, donde jóvenes escuchan y acompañan a personas mayores en el rescate de sus memorias."
                  role="img"
                  class="w-full h-[500px] object-cover object-center transform hover:scale-105 transition-transform duration-700"
                />
              </div>
            </div>
  
          </div>
        </section>
      </div>

      <!-- --- 2. About Section --- -->
      <section id="sobre-el-proyecto" class="py-24 bg-white relative sr-fade-up">
        <div class="container mx-auto px-6">
          <div class="flex flex-col md:flex-row items-center gap-16">
            
            <!-- Left Image -->
            <div class="w-full md:w-5/12 relative">
               <div class="absolute -inset-4 bg-amber-100 rounded-[3rem] transform rotate-3 z-0"></div>
               <img 
                 src="/images/puentes-de-papel-grupo-voluntarios-adultos-mayores-historias.webp" 
                 alt="Dos adultos mayores y dos jóvenes voluntarios reunidos alrededor de una mesa con papeles y libretas, compartiendo memorias en el proyecto Puentes de Papel"
                 title="Grupo de voluntarios y adultos mayores compartiendo historias en Puentes de Papel"
                 aria-label="Sesión grupal del proyecto Puentes de Papel de Munay Ruray, promoviendo el vínculo intergeneracional a través del diálogo, la escucha activa y la escritura colaborativa."
                 role="img"
                 class="relative z-10 w-full h-[450px] object-cover rounded-[2.5rem]"
               />
               <div class="absolute bottom-8 -right-8 bg-white border border-slate-100 px-6 py-4 rounded-2xl z-20 flex items-center gap-4">
                 <div class="bg-green-100 p-3 rounded-full">
                   <Users class="w-6 h-6 text-green-600" />
                 </div>
                 <div>
                   <p class="font-extrabold text-slate-900 text-xl">+500</p>
                   <p class="text-xs font-bold text-slate-500 uppercase">Voluntarios</p>
                 </div>
               </div>
            </div>

            <!-- Right Text -->
            <div class="w-full md:w-7/12">
              <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-8">
                Sobre Puentes de Papel
              </h2>
              <div class="space-y-6 text-xl text-slate-600 leading-relaxed">
                <p>
                  <span class="font-bold text-[#A65F4C]">Puentes de Papel</span> es un proyecto que promueve el encuentro entre generaciones a través de la escucha, la conversación y la escritura.
                </p>
                <p>
                  Muchas personas mayores poseen un gran caudal de experiencias y aprendizajes que forman parte de nuestra memoria colectiva. Sin embargo, muchas de estas historias no llegan a ser registradas o compartidas.
                </p>
                <p>
                  A través de este programa, jóvenes voluntarios acompañan a adultos mayores en un proceso de diálogo y narración de sus memorias, transformando esas historias en relatos que preservan sus experiencias y fortalecen el vínculo entre generaciones.
                </p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- --- Nuestra Esencia Section --- -->
      <section class="py-24 bg-[#FCF9F5] border-y border-orange-100/50 relative sr-fade-up">
        <!-- Subtle heart floating icon in the background -->
        <div class="absolute -top-12 left-1/4 text-rose-200/30 pointer-events-none select-none">
          <Heart class="w-24 h-24 fill-current" />
        </div>
        
        <div class="container mx-auto px-6 max-w-5xl">
          <!-- Section Title -->
          <div class="text-center mb-16">
            <span class="text-sm font-bold text-[#A65F4C] tracking-widest uppercase">Nuestra Alma</span>
            <h2 class="text-4xl md:text-5xl font-black text-slate-900 mt-2 mb-4">
              La esencia de Puentes de Papel
            </h2>
            <div class="w-16 h-1 bg-[#DD8574] rounded-full mx-auto"></div>
          </div>
          
          <!-- Staggered Layered Letter Card for the Manifesto Quote -->
          <div class="relative max-w-4xl mx-auto mb-20 sr-fade-up-delayed">
            <!-- Background sheet 2 (deepest) -->
            <div class="absolute inset-0 bg-[#F5EFE6] rounded-[2rem] shadow-sm transform -rotate-1.5 translate-y-1"></div>
            <!-- Background sheet 1 (middle) -->
            <div class="absolute inset-0 bg-[#FAF7F2] rounded-[2rem] shadow-md transform rotate-1 translate-y-0.5"></div>
            
            <!-- Main Letter Sheet (top) -->
            <div class="relative bg-[#FDFDFB] rounded-[2rem] p-8 md:p-16 lg:p-20 shadow-xl border border-[#EBE3D5] transform rotate-[-0.5deg] overflow-hidden">
              <!-- Vintage double line border framing the letter -->
              <div class="absolute inset-3 border border-[#A65F4C]/15 pointer-events-none rounded-[1.8rem]"></div>
              <div class="absolute inset-4 border border-dashed border-[#A65F4C]/10 pointer-events-none rounded-[1.7rem]"></div>
              
   
              <!-- Big Letter Quote in Garamond serif -->
              <div class="relative z-10 max-w-2xl mx-auto">
                <span class="text-6xl font-serif-literary text-[#DD8574]/20 absolute -top-8 -left-8 md:-left-12 select-none">“</span>
                <p class="font-serif-literary text-2xl md:text-3xl text-slate-800 leading-relaxed font-medium italic text-center text-pretty">
                  Creemos en el poder de las palabras para acercar personas que, tal vez, nunca se hubieran encontrado. Puentes de Papel nace para transformar la distancia en compañía y las cartas en vínculos reales. En un mundo cada vez más rápido, apostamos por volver a mirar al otro con tiempo, escucha y humanidad.
                </p>
                <span class="text-6xl font-serif-literary text-[#DD8574]/20 absolute -bottom-16 -right-6 select-none">”</span>
                
                <!-- Separator line -->
                <div class="w-32 h-[1px] bg-gradient-to-r from-transparent via-[#A65F4C]/20 to-transparent mx-auto my-8"></div>
                
                <!-- Calligraphic signature and seal -->
                <div class="flex items-center justify-between mt-6">
                  <!-- Wax Seal Graphic / Medalla -->
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#A65F4C]/5 flex items-center justify-center border border-[#A65F4C]/10 text-[#A65F4C]">
                      <Users class="w-5 h-5" />
                    </div>
                    <span class="text-xs uppercase tracking-widest text-slate-400 font-bold select-none">Manifiesto Colectivo</span>
                  </div>
                  
                  <!-- Handwritten Signature -->
                  <div class="text-right">
                    <span class="font-handwritten text-4xl text-[#A65F4C] block select-none leading-none">
                      Puentes de Papel
                    </span>
                    <span class="text-[10px] uppercase tracking-widest text-[#DD8574] font-bold">
                      Munay Ruray
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- The 6 Pillars (designed as clean cards matching the site's design language, with text-xl size) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Pillar 1 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-orange-50 border border-orange-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <Heart class="w-6 h-6 text-[#A65F4C] fill-[#A65F4C]/10" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">Combatir la soledad</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">Creamos compañía en las horas silenciosas, llevando palabras que abrigan y acompañan.</p>
                </div>
              </div>
            </div>

            <!-- Pillar 2 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-amber-50 border border-amber-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <Users class="w-6 h-6 text-amber-600" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">Vínculos reales</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">No es un contacto efímero; es una relación de cariño y respeto que se siembra mes a mes.</p>
                </div>
              </div>
            </div>

            <!-- Pillar 3 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <MessageCircle class="w-6 h-6 text-blue-600" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">El valor de escuchar</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">Detenerse a oír con atención, rescatando la sabiduría que solo dan los años.</p>
                </div>
              </div>
            </div>

            <!-- Pillar 4 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-rose-50 border border-rose-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <Sparkles class="w-6 h-6 text-rose-500" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">Pequeños gestos</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">Una carta escrita a mano es un puente que demuestra que cada vida y cada historia importan.</p>
                </div>
              </div>
            </div>

            <!-- Pillar 5 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-emerald-50 border border-emerald-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <Clock class="w-6 h-6 text-emerald-600" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">Tiempo y cuidado</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">Promovemos un ritmo más humano en la comunicación, valorando la espera y la reflexión.</p>
                </div>
              </div>
            </div>

            <!-- Pillar 6 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm hover:-translate-y-1.5 transition-all duration-300 group h-full flex flex-col justify-between">
                <div>
                  <div class="w-12 h-12 rounded-2xl bg-purple-50 border border-purple-100 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
                    <PenTool class="w-6 h-6 text-purple-600" />
                  </div>
                  <h3 class="font-bold text-slate-900 text-2xl mt-6 mb-3">Memoria activa</h3>
                  <p class="text-slate-600 text-xl leading-relaxed">Escribir para atesorar, rescatando anécdotas, vivencias y saberes que trascienden el tiempo.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- --- 3. How it Works Section --- -->
      <section id="como-funciona" class="py-24 bg-slate-50 relative overflow-hidden sr-fade-up">
        <!-- Decorative elements -->
        <div class="absolute top-20 right-10 text-[#F2EADD]">
           <Star class="w-16 h-16 fill-current" />
        </div>
        
        <div class="container mx-auto px-6 relative z-10">
          <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-4">
              ¿Cómo funciona el proyecto?
            </h2>
            <div class="w-24 h-1.5 bg-amber-400 rounded-full mx-auto"></div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Card 1 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] overflow-hidden border border-slate-100 hover:-translate-y-2 transition-transform duration-300 group h-full">
                <div class="h-40 bg-rose-100 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute w-32 h-32 bg-rose-200 rounded-full -right-10 -top-10 opacity-50 group-hover:scale-110 transition-transform duration-500"></div>
                  <UserPlus class="w-16 h-16 text-rose-500 relative z-10" />
                </div>
                <div class="p-8 text-center">
                  <h3 class="text-2xl font-bold text-slate-900 mb-3">Paso 1</h3>
                  <p class="text-slate-600 font-medium text-xl">Adultos mayores y voluntarios se inscriben al programa.</p>
                </div>
              </div>
            </div>

            <!-- Card 2 -->
            <div class="sr-fade-up-delayed">
              <div class="bg-white rounded-[2rem] overflow-hidden border border-slate-100 hover:-translate-y-2 transition-transform duration-300 group h-full">
                <div class="h-40 bg-amber-100 flex items-center justify-center relative overflow-hidden">
                  <div class="absolute w-32 h-32 bg-amber-200 rounded-full -left-10 -bottom-10 opacity-50 group-hover:scale-110 transition-transform duration-500"></div>
                  <Heart class="w-16 h-16 text-amber-500 relative z-10" />
                </div>
                <div class="p-8 text-center">
