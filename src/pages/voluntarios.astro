---
import BaseLayout from '../components/BaseLayout.astro';
import BackButton from '../components/BackButton.astro';
import FormCard from '../components/FormCard.astro';
import { Heart, Send, Sparkles, Check } from 'lucide-astro';

const title = 'Unirte como Voluntario/a - Puentes de Papel';
const description = 'Regala tu tiempo y tus palabras. Inscríbete en Puentes de Papel para comenzar un intercambio mensual de cartas y acompañamiento con un adulto mayor.';
---

<BaseLayout title={title} description={description}>
  <div class="bg-[#FDFBF7] text-slate-800 font-sans min-h-screen">
    
    <!-- Top Navigation / Back button -->
    <BackButton />

    <main class="container mx-auto px-6 pb-24 max-w-3xl">
      <!-- Page Header -->
      <div class="text-center mb-12">
        <div class="w-16 h-16 rounded-full bg-rose-100 flex items-center justify-center mx-auto mb-6 text-rose-500">
          <Heart class="w-8 h-8 fill-rose-500/20" />
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-4">
          Quiero ser voluntario/a
        </h1>
        <p class="text-lg md:text-xl text-slate-600 max-w-xl mx-auto leading-relaxed font-light">
          Tus palabras tienen el poder de abrigar un corazón. Completa esta breve ficha para ayudarnos a encontrar tu match intergeneracional ideal.
        </p>
      </div>

      <!-- Form Card Container -->
      <FormCard>
        <!-- Progress Steps -->
        <div id="progress-container" class="flex justify-between items-center mb-12 relative max-w-md mx-auto">
          <!-- Connector line -->
          <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-slate-100 -translate-y-1/2 z-0"></div>
          <div id="progress-bar" class="absolute left-0 top-1/2 h-0.5 bg-[#A65F4C] -translate-y-1/2 z-0 transition-all duration-300" style="width: 0%;"></div>

          <!-- Step 1 -->
          <div class="step-node relative z-10 flex flex-col items-center">
            <div class="w-10 h-10 rounded-full bg-[#A65F4C] text-white font-bold flex items-center justify-center shadow-md transition-all duration-300 ring-4 ring-[#F2EADD]">1</div>
            <span class="text-xs font-bold text-[#A65F4C] mt-2">Sobre ti</span>
          </div>
          <!-- Step 2 -->
          <div class="step-node relative z-10 flex flex-col items-center">
            <div class="w-10 h-10 rounded-full bg-white text-slate-400 border-2 border-slate-200 font-bold flex items-center justify-center transition-all duration-300">2</div>
            <span class="text-xs font-bold text-slate-400 mt-2">Intereses</span>
          </div>
          <!-- Step 3 -->
          <div class="step-node relative z-10 flex flex-col items-center">
            <div class="w-10 h-10 rounded-full bg-white text-slate-400 border-2 border-slate-200 font-bold flex items-center justify-center transition-all duration-300">3</div>
            <span class="text-xs font-bold text-slate-400 mt-2">Compromiso</span>
          </div>
        </div>

        <!-- The Form -->
        <form id="form-voluntarios" class="space-y-8" data-script-url={import.meta.env.PUBLIC_APPS_SCRIPT_URL}>
          
          <!-- STEP 1: Datos Personales -->
          <div id="step-1" class="form-step space-y-6">
            <h2 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3 flex items-center gap-2">
              <span class="text-[#A65F4C]">1.</span> Datos Personales
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="nombre" class="block text-slate-700 font-bold mb-2">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Tu nombre completo" />
              </div>
              
              <div>
                <label for="apellido" class="block text-slate-700 font-bold mb-2">Apellido *</label>
                <input type="text" id="apellido" name="apellido" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Tu apellido completo" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <label for="dni" class="block text-slate-700 font-bold mb-2">DNI / Documento *</label>
                <input type="text" id="dni" name="dni" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Número de documento" />
              </div>

              <div>
                <label for="edad" class="block text-slate-700 font-bold mb-2">Edad *</label>
                <input type="number" id="edad" name="edad" required min="14" max="110" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Tengo..." />
              </div>

              <div>
                <label for="fechaNacimiento" class="block text-slate-700 font-bold mb-2">Fecha de nacimiento *</label>
                <input type="date" id="fechaNacimiento" name="fechaNacimiento" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" />
              </div>
            </div>

            <div>
              <span class="block text-slate-700 font-bold mb-3">Género *</span>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="genero" value="Femenino" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Femenino</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="genero" value="Masculino" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Masculino</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="genero" value="Otro" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Otro / Prefiero no decir</span>
                </label>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="telefono" class="block text-slate-700 font-bold mb-2">Teléfono / WhatsApp *</label>
                <input type="tel" id="telefono" name="telefono" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Ej: +51 987 654 321" />
                <p class="text-xs text-slate-400 mt-1">Nos comunicamos principalmente por WhatsApp.</p>
              </div>

              <div>
                <label for="correo" class="block text-slate-700 font-bold mb-2">Correo electrónico *</label>
                <input type="email" id="correo" name="correo" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="tu@correo.com" />
              </div>
            </div>

            <div>
              <label for="ciudad" class="block text-slate-700 font-bold mb-2">Ciudad de residencia *</label>
              <input type="text" id="ciudad" name="ciudad" required class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="¿En qué ciudad vives?" />
            </div>

            <div class="pt-6 flex justify-end">
              <button type="button" class="btn-next w-full sm:w-auto bg-[#A65F4C] text-white font-bold px-8 py-4 rounded-full hover:bg-[#DD8574] hover:-translate-y-0.5 transition-all cursor-pointer">
                Siguiente paso
              </button>
            </div>
          </div>

          <!-- STEP 2: Motivación e Intereses -->
          <div id="step-2" class="form-step hidden space-y-6">
            <h2 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3 flex items-center gap-2">
              <span class="text-[#A65F4C]">2.</span> Tu Motivación e Intereses
            </h2>

            <div>
              <label for="motivacion" class="block text-slate-700 font-bold mb-2">¿Por qué te interesa participar en Puentes de Papel? *</label>
              <textarea id="motivacion" name="motivacion" required rows="4" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800 resize-none" placeholder="Cuéntanos un poquito qué te inspiró a sumarte..."></textarea>
            </div>

            <div>
              <span class="block text-slate-700 font-bold mb-3">¿Tenés experiencia previa en voluntariado o acompañamiento social? *</span>
              <div class="flex gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-6 py-4 cursor-pointer transition-colors flex-1">
                  <input type="radio" name="experiencia" value="Sí" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Sí</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-6 py-4 cursor-pointer transition-colors flex-1">
                  <input type="radio" name="experiencia" value="No" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">No</span>
                </label>
              </div>
            </div>

            <div>
              <label for="intereses" class="block text-slate-700 font-bold mb-2">¿Qué temas te interesan o te gustan? *</label>
              <textarea id="intereses" name="intereses" required rows="3" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800 resize-none" placeholder="Ej: literatura, plantas, música antigua, tejer, cine, anécdotas de viajes..."></textarea>
              <p class="text-xs text-slate-400 mt-1">Esto nos ayuda a encontrar un adulto mayor con quien compartas gustos afines.</p>
            </div>

            <div>
              <span class="block text-slate-700 font-bold mb-3">¿Qué tipo de vínculo te gustaría generar? *</span>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="vinculo" value="Escucha y acompañamiento" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Escucha y acompañamiento</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="vinculo" value="Intercambio de historias" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Intercambio de historias</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="vinculo" value="Conversaciones más livianas" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Conversaciones más livianas</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" id="vinculo-otro-checkbox" name="vinculo" value="Otro" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Otro / Indiferente</span>
                </label>
              </div>
              <div id="vinculo-otro-input-container" class="hidden mt-4">
                <label for="vinculo-otro-texto" class="block text-slate-600 font-semibold mb-2 text-sm">Por favor, especifica qué tipo de vínculo te gustaría generar:</label>
                <input type="text" id="vinculo-otro-texto" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Ej: Acompañamiento en paseos, lecturas compartidas..." />
              </div>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row justify-between gap-4">
              <button type="button" class="btn-prev border-2 border-slate-200 text-slate-500 font-bold px-8 py-4 rounded-full hover:bg-slate-50 transition-all cursor-pointer">
                Atrás
              </button>
              <button type="button" class="btn-next bg-[#A65F4C] text-white font-bold px-8 py-4 rounded-full hover:bg-[#DD8574] hover:-translate-y-0.5 transition-all cursor-pointer">
                Siguiente paso
              </button>
            </div>
          </div>

          <!-- STEP 3: Compromiso y Cuidado -->
          <div id="step-3" class="form-step hidden space-y-6">
            <h2 class="text-2xl font-bold text-slate-900 border-b border-slate-100 pb-3 flex items-center gap-2">
              <span class="text-[#A65F4C]">3.</span> Compromiso y Cuidado
            </h2>

            <div>
              <span class="block text-slate-700 font-bold mb-3">¿Podés comprometerte a enviar una carta por mes durante al menos 3 meses? *</span>
              <div class="flex gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-6 py-4 cursor-pointer transition-colors flex-1">
                  <input type="radio" name="compromisoMeses" value="Sí" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Sí</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-6 py-4 cursor-pointer transition-colors flex-1">
                  <input type="radio" name="compromisoMeses" value="No" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">No</span>
                </label>
              </div>
            </div>

            <div>
              <span class="block text-slate-700 font-bold mb-3">¿Cuánto tiempo estimado podrías dedicar por mes al programa? *</span>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="tiempoDedicacion" value="Menos de 1 hora" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Menos de 1 hora</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="tiempoDedicacion" value="1 a 2 horas" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">1 a 2 horas</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="tiempoDedicacion" value="Más de 2 horas" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Más de 2 horas</span>
                </label>
              </div>
            </div>

            <div>
              <span class="block text-slate-700 font-bold mb-3">¿Preferís escribir cartas? *</span>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="preferenciaEscritura" value="Manuscritas" required class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Manuscritas</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="preferenciaEscritura" value="Tipeadas" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Tipeadas (a computadora)</span>
                </label>
                <label class="flex items-center gap-3 bg-slate-50 hover:bg-[#F2EADD]/20 border border-slate-100 rounded-2xl px-5 py-4 cursor-pointer transition-colors">
                  <input type="radio" name="preferenciaEscritura" value="Cualquiera" class="w-5 h-5 text-[#A65F4C] focus:ring-[#A65F4C]" />
                  <span class="font-semibold text-slate-700">Cualquiera de las dos</span>
                </label>
              </div>
            </div>

            <div>
              <label for="evitarTemas" class="block text-slate-700 font-bold mb-2">¿Hay algún tema que prefieras evitar en el intercambio? <span class="text-slate-400 font-medium">(Opcional)</span></label>
              <input type="text" id="evitarTemas" name="evitarTemas" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800" placeholder="Ej: política, enfermedades graves, pérdidas familiares..." />
            </div>

            <div>
              <label for="acompanamientoDetalles" class="block text-slate-700 font-bold mb-2">¿Hay algo importante que te gustaría que tengamos en cuenta para el acompañamiento? <span class="text-slate-400 font-medium">(Opcional)</span></label>
              <textarea id="acompanamientoDetalles" name="acompanamientoDetalles" rows="3" class="w-full bg-slate-50 border-2 border-transparent rounded-2xl px-5 py-3.5 focus:bg-white focus:border-[#A65F4C] focus:outline-none transition-all font-medium text-slate-800 resize-none" placeholder="Cualquier aspecto de salud, movilidad, horarios o emocional que nos ayude a cuidarte mejor."></textarea>
            </div>

            <div class="pt-4">
              <label class="flex items-start gap-3 bg-[#FCF9F5] border border-orange-100 rounded-2xl p-5 cursor-pointer hover:bg-[#F2EADD]/20 transition-colors">
                <input type="checkbox" name="aceptacion" required class="w-5 h-5 rounded text-[#A65F4C] focus:ring-[#A65F4C] mt-0.5" />
                <span class="text-sm font-semibold text-slate-700 leading-relaxed">
                  Acepto comprometerme con respeto, cariño y confidencialidad en el intercambio epistolar y entiendo que participaré de una breve capacitación previa para guiarme en este camino. *
                </span>
              </label>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row justify-between gap-4">
              <button type="button" class="btn-prev border-2 border-slate-200 text-slate-500 font-bold px-8 py-4 rounded-full hover:bg-slate-50 transition-all cursor-pointer">
                Atrás
              </button>
              <button type="submit" class="bg-amber-400 text-[#3B1E16] font-bold px-10 py-4.5 rounded-full hover:bg-amber-300 hover:-translate-y-0.5 transition-all shadow-md flex items-center justify-center gap-2 cursor-pointer">
                Enviar postulación
                <Send class="w-5 h-5" />
              </button>
            </div>
          </div>
        </form>

        <!-- Success View (Hidden initially) -->
        <div id="success-view" class="hidden text-center py-12 space-y-8 animate-fade-in">
          <div class="w-24 h-24 rounded-full bg-emerald-100 flex items-center justify-center mx-auto text-emerald-500 relative">
            <div class="absolute inset-0 rounded-full bg-emerald-200 animate-ping opacity-45"></div>
            <Check class="w-12 h-12 relative z-10" />
          </div>
          
          <div class="space-y-4">
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900">
              ¡Gracias por tender este puente, <span id="success-name" class="text-[#A65F4C]"></span>!
            </h2>
            <p class="text-lg md:text-xl text-slate-600 max-w-xl mx-auto leading-relaxed font-light">
              Tu postulación se ha enviado con todo nuestro cariño. Hemos registrado tus intereses y disponibilidad para realizar el mejor emparejamiento posible.
            </p>
            <div class="p-6 bg-[#FCF9F5] border border-orange-100 rounded-3xl max-w-lg mx-auto text-left space-y-3 mt-8">
              <h4 class="font-bold text-[#A65F4C] text-lg flex items-center gap-2">
                <Sparkles class="w-5 h-5 text-amber-500 fill-amber-400" />
                ¿Qué sigue ahora?
              </h4>
              <p class="text-slate-600 text-base leading-relaxed font-light">
                <strong>Valentina Gómez</strong>, nuestra Coordinadora de Acompañamiento, revisará tu ficha y se pondrá en contacto contigo mediante WhatsApp o correo electrónico para coordinar tu breve inducción inicial. ¡Estamos felices de tenerte!
              </p>
            </div>
          </div>

          <div class="pt-8">
            <a href="/" class="inline-flex bg-slate-100 hover:bg-[#F2EADD]/40 hover:text-[#A65F4C] text-slate-700 font-bold px-8 py-4 rounded-full transition-all">
              Volver al inicio
            </a>
          </div>
        </div>

      </FormCard>
    </main>

    <!-- Simple client-side controller for step wizard and success message -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('form-voluntarios');
        const steps = Array.from(document.querySelectorAll('.form-step'));
        const nextButtons = document.querySelectorAll('.btn-next');
        const prevButtons = document.querySelectorAll('.btn-prev');
        const successView = document.getElementById('success-view');
        const progressNodes = document.querySelectorAll('.step-node div');
        const progressLabels = document.querySelectorAll('.step-node span');
        const progressBar = document.getElementById('progress-bar');
        
        let currentStepIdx = 0;

        // Toggle "Otro" text input in vinculo radio buttons
        const vinculoRadios = form.querySelectorAll('input[name="vinculo"]');
        const otroInputContainer = document.getElementById('vinculo-otro-input-container');
        const otroInput = document.getElementById('vinculo-otro-texto');
        
        if (vinculoRadios.length > 0 && otroInputContainer && otroInput) {
          vinculoRadios.forEach(radio => {
            radio.addEventListener('change', () => {
              if (radio.id === 'vinculo-otro-checkbox' && radio.checked) {
                otroInputContainer.classList.remove('hidden');
                otroInput.focus();
              } else {
                otroInputContainer.classList.add('hidden');
                otroInput.value = '';
              }
            });
          });
        }

        const updateProgress = () => {
          const percent = (currentStepIdx / (steps.length - 1)) * 100;
          progressBar.style.width = `${percent}%`;

          progressNodes.forEach((node, idx) => {
            if (idx < currentStepIdx) {
              node.className = 'w-10 h-10 rounded-full bg-emerald-500 text-white font-bold flex items-center justify-center shadow-md transition-all duration-300';
              node.innerHTML = '✓';
              progressLabels[idx].className = 'text-xs font-bold text-emerald-600 mt-2';
            } else if (idx === currentStepIdx) {
              node.className = 'w-10 h-10 rounded-full bg-[#A65F4C] text-white font-bold flex items-center justify-center shadow-md transition-all duration-300 ring-4 ring-[#F2EADD]';
              node.innerHTML = idx + 1;
              progressLabels[idx].className = 'text-xs font-bold text-[#A65F4C] mt-2';
            } else {
              node.className = 'w-10 h-10 rounded-full bg-white text-slate-400 border-2 border-slate-200 font-bold flex items-center justify-center transition-all duration-300';
              node.innerHTML = idx + 1;
              progressLabels[idx].className = 'text-xs font-bold text-slate-400 mt-2';
            }
          });
        };

        const validateStep = (stepIdx) => {
          const fields = steps[stepIdx].querySelectorAll('input[required], textarea[required], select[required]');
          let isValid = true;
          fields.forEach(field => {
            if (field.type === 'radio') {
              const name = field.name;
              const checked = steps[stepIdx].querySelector(`input[name="${name}"]:checked`);
              if (!checked) {
                isValid = false;
                const parent = field.closest('div');
                if (parent) parent.classList.add('ring-2', 'ring-rose-300', 'rounded-2xl');
              } else {
                const parent = field.closest('div');
                if (parent) parent.classList.remove('ring-2', 'ring-rose-300', 'rounded-2xl');
              }
            } else if (field.type === 'checkbox') {
              if (!field.checked) {
                isValid = false;
                field.classList.add('ring-2', 'ring-rose-300');
              } else {
                field.classList.remove('ring-2', 'ring-rose-300');
              }
            } else {
              if (!field.value.trim()) {
                isValid = false;
                field.classList.add('border-rose-400');
                field.classList.remove('border-transparent');
              } else {
                field.classList.remove('border-rose-400');
                field.classList.add('border-transparent');
              }
            }
          });
          return isValid;
        };

        nextButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            if (validateStep(currentStepIdx)) {
              steps[currentStepIdx].classList.add('hidden');
              currentStepIdx++;
              steps[currentStepIdx].classList.remove('hidden');
              updateProgress();
              window.scrollTo({ top: 200, behavior: 'smooth' });
            } else {
              const firstInvalid = steps[currentStepIdx].querySelector('.border-rose-400, .ring-rose-300');
              if (firstInvalid) {
                firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            }
          });
        });

        prevButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            steps[currentStepIdx].classList.add('hidden');
            currentStepIdx--;
            steps[currentStepIdx].classList.remove('hidden');
            updateProgress();
            window.scrollTo({ top: 200, behavior: 'smooth' });
          });
        });

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (validateStep(currentStepIdx)) {
            const nombreVal = document.getElementById('nombre').value;
            
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalBtnHtml = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = `
              <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-[#3B1E16] inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Enviando...
            `;

            const formData = new FormData(form);
            const fields = {};
            
            for (const [key, value] of formData.entries()) {
              if (key === 'aceptacion') continue;
              
              if (fields[key]) {
                if (!Array.isArray(fields[key])) {
                  fields[key] = [fields[key]];
                }
                fields[key].push(value);
              } else {
                fields[key] = value;
              }
            }

            const selectedVinculo = form.querySelector('input[name="vinculo"]:checked');
            if (selectedVinculo) {
              if (selectedVinculo.value === 'Otro') {
                const otroTexto = document.getElementById('vinculo-otro-texto').value.trim();
                fields['vinculo'] = otroTexto ? `Otro: ${otroTexto}` : 'Otro';
              } else {
                fields['vinculo'] = selectedVinculo.value;
              }
            }

            if (fields['fechaNacimiento']) {
              const parts = fields['fechaNacimiento'].split('-');
              if (parts.length === 3) {
                fields['fechaNacimiento'] = `${parts[2]}/${parts[1]}/${parts[0]}`;
              }
            }

            const payload = {
              sheetName: 'Voluntarios',
              fields: fields
            };

            try {
              const url = form.dataset.scriptUrl;
              if (!url) {
                throw new Error('La URL de Google Apps Script no está configurada. Por favor, crea un archivo .env con PUBLIC_APPS_SCRIPT_URL o configúrala en el formulario.');
              }

              await fetch(url, {
                method: 'POST',
                mode: 'no-cors',
                headers: {
                  'Content-Type': 'text/plain;charset=utf-8'
                },
                body: JSON.stringify(payload)
              });

              document.getElementById('progress-container').classList.add('hidden');
              form.classList.add('hidden');
              
              document.getElementById('success-name').innerText = nombreVal;
              successView.classList.remove('hidden');
              window.scrollTo({ top: 150, behavior: 'smooth' });
            } catch (err) {
              console.error('Error al enviar:', err);
              alert('Error al enviar el formulario: ' + err.message);
              
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalBtnHtml;
            }
          }
        });
      });
    </script>
  </div>
</BaseLayout>
